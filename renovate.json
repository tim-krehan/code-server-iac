{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["^Dockerfile$"],
      "matchStrings": [
        "# (?<datasource>.+)\\nARG (?<depName>[A-Z0-9]+)_VERSION=(?<currentValue>[\\d\\.]+)"
      ],
      "depName": "golang/go",
      "datasource": "github-tags",
      "versioning": "semver"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    }
  ]
}
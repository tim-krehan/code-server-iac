{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["^Dockerfile$"],
      "matchStrings": [
        "# (?<datasource>[^:]+):(?<depName>[^\\s]+)\\s*\\nARG (?<argName>[A-Z0-9_]+)_VERSION=(?<currentValue>[\\d\\.]+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    }
  ]
}